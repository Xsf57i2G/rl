void vertex() {
// Input:3
	float n_out3p0 = TIME;


// UVFunc:6
	vec2 n_in6p1 = vec2(1.00000, 1.00000);
	vec2 n_out6p0 = vec2(n_out3p0) * n_in6p1 + UV;


// Texture2D:5
	vec4 n_out5p0 = texture(tex_vtx_5, n_out6p0);


// Input:4
	vec3 n_out4p0 = NORMAL;


// VectorOp:7
	vec3 n_in7p1 = vec3(0.70000, 0.70000, 0.70000);
	vec3 n_out7p0 = n_out4p0 * n_in7p1;


// VectorOp:2
	vec3 n_out2p0 = vec3(n_out5p0.xyz) * n_out7p0;


// Output:0
	VERTEX = n_out2p0;


}

void fragment() {
// Texture2D:2
	vec4 n_out2p0 = texture(tex_frg_2, UV);


// Output:0
	ALBEDO = vec3(n_out2p0.xyz);
	ALPHA = n_out2p0.x;
	EMISSION = vec3(n_out2p0.xyz);


}
